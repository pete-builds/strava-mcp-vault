# Strava API credentials (from https://www.strava.com/settings/api)
STRAVA_CLIENT_ID=your-client-id
STRAVA_CLIENT_SECRET=your-client-secret

# Initial tokens from OAuth flow (see README)
# After first boot, tokens are managed automatically in SQLite
STRAVA_ACCESS_TOKEN=your-initial-access-token
STRAVA_REFRESH_TOKEN=your-initial-refresh-token

# Optional: change the server port (default: 18201)
# STRAVA_MCP_PORT=18201

# Optional: bind to a specific IP (default: 0.0.0.0)
# Useful for restricting access to a VPN interface (e.g. Tailscale)
# MCP_BIND_HOST=100.x.x.x

# Optional: bearer token for MCP endpoint authentication
# If set, clients must send Authorization: Bearer <token> header
# MCP_AUTH_TOKEN=your-secret-token

# Optional: Fernet key for encrypting tokens at rest in SQLite
# Generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If not set, tokens are stored in plaintext (still protected by .env and file permissions)
# TOKEN_ENCRYPTION_KEY=your-fernet-key
